{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "harness-runtime",
  "version": "0.0.0",
  "description": "Runnable OpenCode plugin scaffold for harness",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "check": "tsc --noEmit",
    "build": "bun build src/index.ts --outdir dist --target bun --format esm && tsc --emitDeclarationOnly",
    "clean": "rm -rf dist",
    "prepare": "bun run build"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.14.18",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "bun": "^1.3.12",
    "oxlint": "^1.60.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
